# Base de datos (Supabase → Settings → Database → Connection string → URI)
DATABASE_URL="postgresql://postgres:[TU-PASSWORD]@db.[TU-REF].supabase.co:5432/postgres"

# NextAuth — genera el secret con:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Core — plataforma de IA (github.com/tu-usuario/AI-Core)
# Dev local: AI Core corre en localhost:8001 (8000 lo ocupa el contenedor de Chroma)
# Producción: URL pública donde esté desplegado AI Core (tunnel o VPS)
AI_CORE_BASE_URL="http://localhost:8001"
# Genera la key con: python backend/scripts/create_api_key.py cip
AI_CORE_API_KEY=""
